# --- LLM (answer generation) ---
# Option A: OpenAI (paid). Get key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Option B: Free local LLM via Ollama (no key needed). Install: https://ollama.com then run: ollama pull llama3.2
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2

# If both OPENAI_API_KEY and OPENAI_API_BASE are unset, answers will be fallback-only unless retrieval score is high and key is set elsewhere.

# CORS — comma-separated origins (scheme + host + port, NO trailing slash).
# Empty = allow * (any origin). Fine for local / Swagger.
#
# If frontend and API are on different domains, you MUST list your site origins or the browser shows "Failed to fetch":
#   CORS_ORIGINS=https://vahdetkaratas.com,https://www.vahdetkaratas.com
# Do not set only localhost here in production — that blocks your live portfolio page.
#
# CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# If best retrieval score (cosine / inner product) is below this, LLM is not called. 0 or unset = disabled.
# RETRIEVAL_MIN_SCORE=0.22

# Abuse protection when using OpenAI (recommended):
# - RAG_API_KEY: only clients with this key can call /ask. Use a strong secret.
# - API_RATE_LIMIT: max requests per minute per key (or per IP if no key). Default 30/minute.
# - API_RATE_LIMIT_HOUR: default 100/hour (portfolio). Applied with API_RATE_LIMIT. Disable with off | none | 0.
# Per-minute limit for POST /ask (slowapi). To disable: off | none | 0 | false
# API_RATE_LIMIT=30/minute
# Hourly cap: default 100/hour (portfolio-friendly). Applied together with API_RATE_LIMIT. To disable: off | none | 0
# API_RATE_LIMIT_HOUR=100/hour

# Optional API key for REST /ask (comma-separated for multiple). Empty = no check.
# When set, rate limit is applied per key (so each client is capped). Header: X-RAG-API-Key or Authorization: Bearer <key>
# RAG_API_KEY=your-rag-secret

# Optional: absolute project root in Docker/VPS if layout differs (default: parent of src/)
# RAG_PROJECT_ROOT=/app

# Logging (optional; uvicorn may also set level)
# LOG_LEVEL=INFO

# Windows: disable Hugging Face symlink warning (optional)
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
